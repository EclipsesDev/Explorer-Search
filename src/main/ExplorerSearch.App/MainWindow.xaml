<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ExplorerSearch.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ExplorerSearch.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ExplorerSearch.Core.Models"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox
                x:Name="QueryTextBox"
                Width="440"
                PlaceholderText="Type part of file name (example: Minecraft)"
                KeyDown="QueryTextBox_KeyDown" />
            <Button
                x:Name="SearchButton"
                Content="Search"
                Click="SearchButton_Click" />
            <Button
                x:Name="CancelButton"
                Content="Cancel"
                IsEnabled="False"
                Click="CancelButton_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <TextBox
                x:Name="RootPathTextBox"
                Width="560"
                Header="Root Folder" />
            <CheckBox
                x:Name="IncludeSubfoldersCheckBox"
                VerticalAlignment="Bottom"
                Content="Include subfolders"
                IsChecked="True" />
            <TextBox
                x:Name="MaxResultsTextBox"
                Width="120"
                Header="Max Results"
                Text="200" />
        </StackPanel>

        <ListView
            x:Name="ResultsListView"
            Grid.Row="2"
            IsItemClickEnabled="True"
            SelectionMode="Single"
            ItemClick="ResultsListView_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileSearchResult">
                    <StackPanel Margin="0,4">
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                        <TextBlock
                            FontSize="12"
                            Opacity="0.8"
                            Text="{x:Bind FullPath}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="12" Opacity="0.7">
                            <Run Text="Size: " />
                            <Run Text="{x:Bind SizeBytes}" />
                            <Run Text=" bytes | Updated (UTC): " />
                            <Run Text="{x:Bind LastWriteTime}" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <ProgressRing
                x:Name="BusyRing"
                Width="20"
                Height="20"
                IsActive="False" />
            <ProgressBar
                x:Name="IndexProgressBar"
                Width="220"
                VerticalAlignment="Center"
                Minimum="0"
                Maximum="100"
                Value="0"
                IsIndeterminate="False"
                Visibility="Collapsed" />
            <TextBlock
                x:Name="StatusTextBlock"
                VerticalAlignment="Center"
                Text="Ready." />
            <TextBlock
                x:Name="IndexEtaTextBlock"
                VerticalAlignment="Center"
                Opacity="0.8"
                Visibility="Collapsed" />
            <!--<Button
                x:Name="OpenLocationButton"
                Content="Open File Location"
                IsEnabled="False"
                Click="OpenLocationButton_Click" />-->
        </StackPanel>
    </Grid>
</Window>